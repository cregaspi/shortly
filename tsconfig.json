{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "components/Shortener.jsx", "components/LinkList.jsx", "components/LinkItem.jsx", "app/page.jsx", "app/layout.jsx", "components/Stats.jsx", "components/Navbar.jsx", "components/Hero.jsx", "components/Footer.jsx", "components/Boost.jsx", "app/features/page.jsx"  ],
  "exclude": ["node_modules"]
}
